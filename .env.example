# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Get keys at https://dashboard.stripe.com/apikeys (use test mode keys while developing)
STRIPE_SECRET_KEY=

# Get this after creating a webhook endpoint at https://dashboard.stripe.com/webhooks
# pointed at <your domain>/api/webhook, subscribed to checkout.session.completed.
# For local testing, use the Stripe CLI: `stripe listen --forward-to localhost:3000/api/webhook`
# which prints a temporary webhook secret to use here instead.
STRIPE_WEBHOOK_SECRET=

# Get a key at https://resend.com/api-keys (free tier is enough to start)
RESEND_API_KEY=

# Must be a verified sender on your Resend account, or use the default
# onboarding@resend.dev sandbox address while testing
RESEND_FROM_EMAIL=

# Where expert-review purchase notifications get sent — almost certainly your own email
REVIEW_NOTIFICATION_EMAIL=
